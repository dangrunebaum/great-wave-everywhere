rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all operations on the words collection
    // (Cloud Functions run as admin and can bypass these rules)
    // This is for direct access if needed
    match /words/{document=**} {
      allow read, write: if true;
    }
    
    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
